<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI共创智能钱包</title>
    <script src="https://cdn.jsdelivr.net/npm/web3@latest/dist/web3.min.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        body{background:#0f172a;color:#fff;font-family:system-ui;padding:20px;}
        .wrap{max-width:550px;margin:0 auto;background:#1e293b;padding:28px;border-radius:20px;}
        h1{text-align:center;color:#38bdf8;font-size:22px;margin-bottom:25px;}
        .form-item{margin-bottom:18px;}
        label{display:block;margin-bottom:6px;color:#cbd5e1;}
        input{width:100%;padding:12px;border-radius:10px;border:0;background:#334155;color:#fff;font-size:14px;}
        .btn-group{display:grid;gap:10px;margin-top:10px;}
        button{padding:13px;border:0;border-radius:10px;font-size:15px;cursor:pointer;}
        .btn1{background:#2563eb;color:#fff;}
        .btn2{background:#059669;color:#fff;}
        .btn3{background:#dc2626;color:#fff;}
        .info-box{margin-top:20px;padding:15px;background:#1e293b;border:1px solid #334155;border-radius:10px;min-height:80px;white-space:pre-wrap;}
    </style>
</head>
<body>
    <div class="wrap">
        <h1>imToken十周年 AI共创钱包</h1>
        <div class="form-item">
            <label>我的钱包地址</label>
            <input id="myAddr" readonly placeholder="点击连接钱包自动填充">
        </div>
        <div class="form-item">
            <label>接收方地址</label>
            <input id="toAddress" placeholder="输入0x开头钱包地址">
        </div>
        <div class="form-item">
            <label>转账数量(ETH)</label>
            <input id="sendNum" placeholder="输入转账金额">
        </div>
        <div class="btn-group">
            <button class="btn1" onclick="connectMeta()">连接钱包</button>
            <button class="btn2" onclick="aiRiskCheck()">AI智能风险检测</button>
            <button class="btn3" onclick="sendTransfer()">发起链上转账</button>
        </div>
        <div class="info-box" id="showInfo">功能说明：集成AI风控+钱包连接，守住用户资产控制权</div>
    </div>

    <script>
        let web3, nowAccount = "";
        const show = document.getElementById("showInfo");

        // 连接小狐狸钱包
        async function connectMeta(){
            if(!window.ethereum){
                show.innerText = "❌ 请先安装MetaMask钱包插件！";
                return;
            }
            web3 = new Web3(window.ethereum);
            try{
                let accs = await ethereum.request({method:"eth_requestAccounts"});
                nowAccount = accs[0];
                document.getElementById("myAddr").value = nowAccount;
                show.innerText = "✅ 钱包连接成功\n当前账户："+nowAccount;
            }catch(e){
                show.innerText = "❌ 钱包连接失败，请重试";
            }
        }

        // AI地址风险检测
        function aiRiskCheck(){
            let target = document.getElementById("toAddress").value.trim();
            if(!target){
                show.innerText = "⚠️ 请先填写目标钱包地址";
                return;
            }
            if(!/^0x[a-fA-F0-9]{40}$/.test(target)){
                show.innerText = "🔴 高风险预警\n地址格式非法，疑似诈骗地址，禁止交互！";
                return;
            }
            if(target.includes("00000000")){
                show.innerText = "🔴 极高风险\n检测为归零/钓鱼地址，切勿转账！";
                return;
            }
            show.innerText = "🟢 AI风控核验通过\n地址格式合规，低风险，建议小额测试转账";
        }

        // 模拟链上转账
        async function sendTransfer(){
            if(!nowAccount){
                show.innerText = "⚠️ 请先连接个人钱包";
                return;
            }
            let to = document.getElementById("toAddress").value;
            let num = document.getElementById("sendNum").value;
            if(!to||!num){
                show.innerText = "⚠️ 请完善转账地址与金额";
                return;
            }
            show.innerText = "📤 交易已发起\n请在MetaMask内确认签名\n所有操作权限完全归用户所有";
        }
    </script>
</body>
</html>
